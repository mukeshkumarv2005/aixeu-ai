# ─── Application ───────────────────────────────────────────────
APP_NAME=Aevix
APP_VERSION=0.1.0
APP_DEBUG=true
APP_ENV=development

# ─── Backend ───────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aevix:aevix@localhost:5432/aevix
DATABASE_SYNC_URL=postgresql://aevix:aevix@localhost:5432/aevix
POSTGRES_USER=aevix
POSTGRES_PASSWORD=aevix
POSTGRES_DB=aevix
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Security ──────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── AI Providers ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Default AI provider: openai | anthropic | azure | local
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o

# ─── File Storage ──────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
MAX_UPLOAD_SIZE_MB=50

# ─── Vector Store ─────────────────────────────────────────────-
VECTOR_STORE_TYPE=pgvector

# ─── Docker ────────────────────────────────────────────────────
DOCKER_NETWORK=aevix-network
