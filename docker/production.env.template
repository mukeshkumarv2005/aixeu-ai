# Aevix Production Environment Configurations

# ─── Application ───────────────────────────────────────────────
APP_NAME=Aevix
APP_VERSION=0.1.0
APP_DEBUG=false
APP_ENV=production
ASYNC_WORKERS=true

# ─── Security ──────────────────────────────────────────────────
# REQUIRED: Generate a long random secret key (e.g., openssl rand -hex 32)
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
REFRESH_TOKEN_CLEANUP_INTERVAL_MINUTES=60

# ─── Database (PostgreSQL) ────────────────────────────────────
# The backend uses Asyncpg: postgresql+asyncpg://<user>:<password>@postgres:5432/<db>
POSTGRES_USER=aevix
# REQUIRED: Set a strong database password
POSTGRES_PASSWORD=
POSTGRES_DB=aevix
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ─────────────────────────────────────────────────────
# REQUIRED: Set a strong Redis password
REDIS_PASSWORD=

# ─── AI Providers ──────────────────────────────────────────────
# REQUIRED if using OpenAI (GPT models or text-embedding-3-small)
OPENAI_API_KEY=
# REQUIRED if using Anthropic (Claude models)
ANTHROPIC_API_KEY=

AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ─── File Storage ──────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_UPLOAD_DIR=./storage
STORAGE_MAX_SIZE_MB=50
